{
  "name": "narrowland",
  "version": "1.8.2",
  "description": "A lightweight TypeScript library providing type-safe assertions, type guards, and error handling utilities.",
  "keywords": [
    "assert",
    "invariant",
    "narrowing",
    "type-guards",
    "typescript"
  ],
  "bugs": {
    "url": "https://github.com/marekh19/narrowland/issues"
  },
  "license": "MIT",
  "author": "Marek Honzal <hi@marekhonzal.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/marekh19/narrowland.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "prepare": "husky",
    "prepublishOnly": "pnpm build",
    "build": "tsdown",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "dev": "tsdown --watch",
    "format:check": "oxfmt --check",
    "format:fix": "oxfmt",
    "test": "vitest run --typecheck",
    "test:ci": "tsc -p tsconfig.test.json && pnpm run test && pnpm run test:size",
    "test:size": "size-limit",
    "test:coverage": "vitest run --typecheck --coverage",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "knip": "^6.25.0",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "preset-small-lib": "link:@size/limit/preset-small-lib",
    "size-limit": "^12.1.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
