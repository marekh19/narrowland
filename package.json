{
  "name": "narrowland",
  "version": "1.8.1",
  "description": "A lightweight TypeScript library providing type-safe assertions, type guards, and error handling utilities.",
  "keywords": [
    "assert",
    "invariant",
    "narrowing",
    "type-guards",
    "typescript"
  ],
  "bugs": {
    "url": "https://github.com/marekh19/narrowland/issues"
  },
  "license": "MIT",
  "author": "Marek Honzal <hi@marekhonzal.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/marekh19/narrowland.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "prepare": "husky",
    "build": "tsdown",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "dev": "tsdown --watch",
    "format:check": "oxfmt --check",
    "format:fix": "oxfmt",
    "test": "vitest run --typecheck",
    "test:ci": "tsc -p tsconfig.test.json && pnpm run test && pnpm run test:size",
    "test:size": "size-limit",
    "test:coverage": "vitest run --typecheck --coverage",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "preset-small-lib": "link:@size/limit/preset-small-lib",
    "size-limit": "^12.1.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd"
}
